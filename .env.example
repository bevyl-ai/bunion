# ── target repo ──
REPO=owner/name
BASE_BRANCH=main

# ── linear ──
LINEAR_API_KEY=lin_api_xxx
LINEAR_TEAM=BEV

# ── states: the board IS the gate. Names exactly as they appear in Linear. ──
# Any of these triggers a pickup (comma-separated — e.g. a fresh queue + a rework column):
READY_STATES=Bunion ready,Rework
# bunion moves the ticket through these as it works:
WORKING_STATE=Bunion working
REVIEW_STATE=In review
ESCALATE_STATE=Needs human
# (your board can have any number of other states — triage, blocked, done, … — bunion ignores them.)

# ── run ──
MAX_CONCURRENT=3
POLL_MS=15000
# commands run in the worktree before a PR is opened; ';'-separated; any failure rejects the PR
BACKPRESSURE=bun run typecheck

# ── agent (Codex via the exe.dev gateway — no API key) ──
CODEX_EFFORT=high
CODEX_PROVIDER=
CODEX_MODEL=
CODEX_TIMEOUT_MS=1800000

# ── worker: `local` (runs here, default) or `exedev` (a fresh VM per ticket) ──
PROVIDER=local

# ── paths (optional; sensible defaults under ~/.bunion) ──
WORKDIR=
WORKFLOW_PATH=
