# ── target repo ──
REPO=owner/name
BASE_BRANCH=main

# ── linear ──
LINEAR_API_KEY=lin_api_xxx
LINEAR_TEAM=BEV
FACTORY_LABEL=factory

# ── policy (the gate) ──
MAX_CONCURRENT=3
MAX_ESTIMATE=2
POLL_MS=15000
# component = the `area:<x>` label on the ticket
ALLOWLIST=copy,marketing,glossary,docs
CARVE_OUTS=auth,billing,migrations,rls,secrets,infra
# components allowed to auto-merge once you trust them; empty = every PR is human-merged
AUTO_MERGE=
# commands run in the worktree before a PR is opened; ';'-separated; any failure rejects the PR
BACKPRESSURE=bun run typecheck
# a failed run retries this many times (exponential backoff from RETRY_BACKOFF_MS) before terminal failure
MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=30000

# ── agent (Codex via the exe.dev gateway — no API key) ──
CODEX_EFFORT=high
CODEX_PROVIDER=
CODEX_MODEL=
CODEX_TIMEOUT_MS=1800000

# ── worker: `local` (runs here, default) or `exedev` (a fresh VM per ticket) ──
PROVIDER=local

# ── paths (optional; sensible defaults under ~/.bunion) ──
WORKDIR=
STATE_DB=
WORKFLOW_PATH=
